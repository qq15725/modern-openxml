{
  "name": "modern-openxml-monorepo",
  "type": "module",
  "private": true,
  "version": "1.12.4",
  "packageManager": "pnpm@10.18.1",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "cli": "pnpm -F @modern-openxml/cli cli",
    "stub": "pnpm -F @modern-openxml/cli stub",
    "dev": "vite playground",
    "publish": "pnpm -r publish --no-git-checks --access public",
    "version": "conventional-changelog -p angular -i CHANGELOG.md -s && git add CHANGELOG.md",
    "release": "bumpp package.json packages/*/package.json --commit \"release: v%s\" --push --all --tag"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@types/node": "^25.9.1",
    "bumpp": "^11.1.0",
    "conventional-changelog-cli": "^5.0.0",
    "eslint": "^10.4.0",
    "lint-staged": "^17.0.5",
    "modern-idoc-svg": "^0.3.3",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^6.0.3",
    "unbuild": "^3.6.1",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  }
}
